{
  "name": "hel",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/package/runtime.js",
  "types": "./dist/package/package/runtime.d.ts",
  "files": [
    "dist/package",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/package/package/runtime.d.ts",
      "import": "./dist/package/runtime.js"
    },
    "./runtime": {
      "types": "./dist/package/package/runtime.d.ts",
      "import": "./dist/package/runtime.js"
    },
    "./server": {
      "types": "./dist/package/package/server.d.ts",
      "import": "./dist/package/server.js"
    },
    "./vite": {
      "types": "./dist/package/package/vite.d.ts",
      "import": "./dist/package/vite.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "build:package:js": "node scripts/build-package.mjs",
    "build:package:types": "tsc -p tsconfig.package.json",
    "build:package": "npm run build:package:js && npm run build:package:types",
    "verify:starters": "npm --prefix starter install && npm --prefix starter run typecheck && npm --prefix starter run build && npm --prefix starter-ssr install && npm --prefix starter-ssr run typecheck && npm --prefix starter-ssr run build",
    "verify:package": "node scripts/build-package.mjs && tsc -p tsconfig.package.json && npm run verify:starters",
    "pack:dry-run": "npm pack --dry-run",
    "pack:artifact": "npm pack --pack-destination artifacts",
    "release:check": "npm run typecheck && npm test && npm run build && npm run verify:package && npm run pack:dry-run",
    "prerender": "node scripts/prerender.mjs",
    "build": "npm run build:client && npm run build:server && npm run prerender",
    "bench": "vitest bench --run",
    "bench:runtime": "tsx scripts/bench-runtime.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@babel/generator": "^7.27.0",
    "@babel/parser": "^7.27.0",
    "@babel/traverse": "^7.27.0",
    "@babel/types": "^7.27.0",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^22.13.10",
    "happy-dom": "^20.8.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "solid-js": "^1.9.11",
    "vue": "^3.5.30"
  }
}
