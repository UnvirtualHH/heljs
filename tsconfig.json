{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "hel/runtime": [
        "src/framework/runtime/index.ts"
      ]
    },
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "types": ["node"]
  },
  "include": ["src", "vite.config.ts"],
  "exclude": [
    "src/framework/package/**/*",
    "src/framework/package-runtime.ts",
    "src/framework/package-server.ts",
    "src/framework/package-vite.ts"
  ]
}
